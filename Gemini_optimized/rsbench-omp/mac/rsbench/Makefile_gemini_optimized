CC          = g++
OPTIMIZE    = no
DEBUG       = no

# Standard flags
CFLAGS := -std=c++17 -Wall -march=armv8-a+simd -fopenmp

# Linker flags
LDFLAGS = -lm -fopenmp

# Debug Flags
ifeq ($(DEBUG),yes)
  CFLAGS += -g
endif

# Forced to -O0
CFLAGS += -O0

program = rsbench_gemini_optimized

source = init_gemini_optimized.c io_gemini_optimized.c main_gemini_optimized.c material_gemini_optimized.c simulation_gemini_optimized.c utils_gemini_optimized.c

obj = $(source:.c=.o)

$(program): $(obj)
	$(CC) $(CFLAGS) $(obj) -o $@ $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f *.o $(program)
